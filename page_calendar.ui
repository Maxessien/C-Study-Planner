    <height>650</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Schedule Management</string>
  </property>
  <property name="styleSheet">
   <string>
    QWidget {
        background-color: #1e1e2e;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #cdd6f4;
    }
    QLabel {
        background: transparent;
    }
    /* Header Area styling */
    #labelTitle {
        color: #cdd6f4;
    }
    #labelSubtitle {
        color: #a6adc8;
    }

    /* Navigation Bar Container */
    #navContainer {
        background-color: #11111b;
        border: 1px solid #313244;
        border-radius: 8px;
    }
    #buttonPrevWeek, #buttonNextWeek {
        background-color: transparent;
        color: #a6adc8;
        border: none;
        font-size: 14px;
        font-weight: bold;
    }
    #buttonPrevWeek:hover, #buttonNextWeek:hover {
        color: #89b4fa;
    }
    #labelDateRange {
        color: #cdd6f4;
        font-weight: bold;
    }

    /* Column Container Framing */
    .QFrame[objectName^="col"] {
        border-right: 1px solid #313244;
        background-color: transparent;
    }
    #colSun {
        border-right: none; /* Drop last right border line */
    }
    #colTue {
        background-color: rgba(137, 180, 250, 0.03); /* Subtle active tracking glow tint */
    }

    /* Day Labels Header Area */
    .QLabel[objectName^="lblDayName"] {
        color: #a6adc8;
        font-size: 11px;
        font-weight: bold;
        text-transform: uppercase;
    }
    #lblDayNameTue {
        color: #89b4fa; /* Accent active track day text */
    }
    .QLabel[objectName^="lblDayNum"] {
        color: #cdd6f4;
        font-size: 18px;
        font-weight: bold;
    }

    /* Active Circle Badge Design for Current Date */
    #lblDayNumTue {
        color: #11111b;
        background-color: #89b4fa;
        border-radius: 14px;
        padding: 2px;
    }

    /* Event Scheduler Cards Layout rules */
    .QFrame[objectName^="card"] {
        background-color: #181825;
        border: 1px solid #313244;
        border-radius: 8px;
    }
    .QFrame[objectName^="card"]:hover {
        border: 1px solid #45475a;
        background-color: #252538;
    }
    .QLabel[objectName^="cardTitle"] {
        color: #cdd6f4;
        font-weight: bold;
        font-size: 13px;
    }
    .QLabel[objectName^="cardTime"] {
        color: #a6adc8;
        font-size: 11px;
    }

    /* Catppuccin Dot Badges Category Codes */
    #dotMath { background-color: #b4befe; border-radius: 4px; }
    #dotPhysics { background-color: #f9e2af; border-radius: 4px; }
    #dotHistory { background-color: #f38ba8; border-radius: 4px; }
    #dotLiterature { background-color: #a6e3a1; border-radius: 4px; }
   </string>
  </property>

